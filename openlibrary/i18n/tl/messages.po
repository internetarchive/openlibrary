msgstr "Kopyahin ang mga may-akda sa bagong gawain"

#: books/edit/edition.html
msgid "Copy subjects to new work"
msgstr "Kopyahin ang mga paksa sa bagong gawain"

#: books/edit/edition.html
msgid "Please select an identifier."
msgstr "Mangyaring pumili ng isang identifier."

#: books/edit/edition.html
msgid "You need to give a value to ID."
msgstr "Kailangan mong bigyan ng halaga ang ID."

#: books/edit/edition.html
msgid "ID ids cannot contain whitespace."
msgstr "Ang mga ID ay hindi maaaring maglaman ng whitespace."

#: books/edit/edition.html
msgid "ID must be exactly 10 characters [0-9] or X."
msgstr "Ang ID ay dapat na eksaktong 10 na karakter [0-9] o X."

#: books/edit/edition.html
